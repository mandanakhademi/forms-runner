{
  "name": "GOV.UK Forms Runner",
  "dockerComposeFile": ["docker-compose.yaml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Forms Runner Server",
      "onAutoForward": "notify"
    }
  },
  // Installs Ruby gems, Node modules, and preps the background Redis connections
  // All output is redirected to a log file for debugging.
  "postCreateCommand": "sh -c '(bundle install && npm install && ./bin/setup) > /workspace/post-create.log 2>&1'",
  "customizations": {
    "vscode": {
      "settings": {
        "ruby.lint.rubocop": true
      },
      "extensions": [
        "rebornix.Ruby",
        "castwide.solargraph",
        "misogi.ruby-rubocop",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "remoteUser": "vscode"
}
